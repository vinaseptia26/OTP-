  Future<void> _printReport() async {
    await Printing.layoutPdf(
      onLayout: (PdfPageFormat format) async {
        final pdf = pw.Document();
        Uint8List imageBytes;
        try {
          final data = await rootBundle.load('assets/logo.png');
          imageBytes = data.buffer.asUint8List();
        } catch (e) {
          imageBytes = Uint8List(0);
        }
        final logo = imageBytes.isNotEmpty ? pw.MemoryImage(imageBytes) : null;
        
        pdf.addPage(
          pw.Page(
            pageFormat: format,
            build: (context) {
              final List<pw.Widget> children = [];
              
              if (logo != null) {
                children.add(pw.Image(logo, width: 50, height: 50));
              }
              children.add(pw.SizedBox(height: 20));
              children.add(pw.Text('LAPORAN SISTEM', style: pw.TextStyle(fontSize: 24, fontWeight: pw.FontWeight.bold)));
              children.add(pw.Text('Periode: ${DateFormat('dd MMM yyyy').format(_dateRange.start)} - ${DateFormat('dd MMM yyyy').format(_dateRange.end)}'));
              children.add(pw.SizedBox(height: 20));
              children.add(
                pw.TableHelper.fromTextArray(
                  headers: ['Tanggal', 'Tipe', 'Status', 'User'],
                  data: _reports.take(20).map((report) => [
                    DateFormat('dd/MM/yyyy').format(report.createdAt),
                    _getTypeLabel(report.type),
                    _getStatusLabel(report.status),
                    report.type == 'lembur' 
                        ? (report.data['nama_mitra']?.toString() ?? '-')
                        : (report.data['user_name']?.toString() ?? '-'),
                  ]).toList(),
                ),
              );
              
              return children;
            },
          ),
        );
        
        return pdf.save();
      },
    );
  }
  
  Future<void> _approveReport(String reportId) async {
    try {
      await _firestore.collection('lembur').doc(reportId).update({
        'status': 'disetujui',
        'approved_by': _auth.currentUser?.email,
        'approved_by_id': _auth.currentUser?.uid,
        'approved_by_name': _auth.currentUser?.displayName ?? 'Super Admin',
        'approved_at': FieldValue.serverTimestamp(),
        'updated_at': FieldValue.serverTimestamp(),
      });
      
      await _firestore.collection('activity_logs').add({
        'action': 'approve_report',
        'user': _auth.currentUser?.email,
        'user_id': _auth.currentUser?.uid,
        'user_role': 'superadmin',
        'target_id': reportId,
        'target_type': 'lembur',
        'changes': {'status': 'disetujui'},
        'timestamp': FieldValue.serverTimestamp(),
        'ip_address': '',
        'session_id': '',
      });
      
      _showSuccess('Laporan disetujui');
      _loadData();
    } catch (e) {
      _showError('Gagal approve: $e');
    }
  }
  
  Future<void> _rejectReport(String reportId) async {
    final reasonController = TextEditingController();
    
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('Tolak Laporan'),
        content: TextField(
          controller: reasonController,
          maxLines: 3,
          decoration: const InputDecoration(
            hintText: 'Alasan penolakan...',
            border: OutlineInputBorder(),
          ),
        ),
        actions: [
          TextButton(onPressed: () => Navigator.pop(context), child: const Text('Batal')),
          ElevatedButton(
            onPressed: () async {
              Navigator.pop(context);
              try {
                await _firestore.collection('lembur').doc(reportId).update({
                  'status': 'ditolak',
                  'rejected_by': _auth.currentUser?.email,
                  'rejected_by_id': _auth.currentUser?.uid,
                  'rejected_at': FieldValue.serverTimestamp(),
                  'rejected_reason': reasonController.text,
                  'updated_at': FieldValue.serverTimestamp(),
                });
                
                await _firestore.collection('activity_logs').add({
                  'action': 'reject_report',
                  'user': _auth.currentUser?.email,
                  'user_id': _auth.currentUser?.uid,
                  'user_role': 'superadmin',
                  'target_id': reportId,
                  'target_type': 'lembur',
                  'changes': {'status': 'ditolak', 'reason': reasonController.text},
                  'timestamp': FieldValue.serverTimestamp(),
                });
                
                _showSuccess('Laporan ditolak');
                _loadData();
              } catch (e) {
                _showError('Gagal tolak: $e');
              }
            },
            style: ElevatedButton.styleFrom(backgroundColor: Colors.red),
            child: const Text('Tolak', style: TextStyle(color: Colors.white)),
          ),
        ],
      ),
    );
  }
  
  String _getTypeLabel(String type) {
    switch (type) {
      case 'lembur': return 'Lembur';
      case 'absensi': return 'Absensi';
      case 'system_log': return 'System Log';
      case 'activity': return 'Aktivitas';
      default: return type;
    }
  }
  
  String _getStatusLabel(String status) {
    switch (status) {
      case 'pending': return 'Pending';
      case 'disetujui': return 'Disetujui';
      case 'ditolak': return 'Ditolak';
      case 'selesai': return 'Selesai';
      case 'completed': return 'Selesai';
      default: return status;
    }
  }
  
  Color _getStatusColor(String status) {
    switch (status) {
      case 'pending': return Colors.orange;
      case 'disetujui': return Colors.green;
      case 'ditolak': return Colors.red;
      case 'selesai': return Colors.blue;
      case 'completed': return Colors.blue;
      default: return Colors.grey;
    }
  }
  
