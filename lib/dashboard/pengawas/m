        fungsi = report.data['fungsi_mitra']?.toString() ?? report.data['pengawas_fungsi']?.toString() ?? '-';
        detail = 'Jam: ${report.data['total_jam'] ?? 0} jam\nAlasan: ${report.data['alasan'] ?? '-'}';
      } else if (report.type == 'absensi') {
        user = report.data['user_name']?.toString() ?? '-';
        fungsi = report.data['fungsi']?.toString() ?? '-';
        detail = 'Lokasi: ${report.data['lokasi_nama']?.toString() ?? '-'}';
      } else {
        user = report.data['user']?.toString() ?? '-';
        fungsi = '-';
        detail = report.data['description']?.toString() ?? '-';
      }
      
      sheet.appendRow([
        excel.TextCellValue(report.id.substring(0, 8).toString()),
        excel.TextCellValue(_getTypeLabel(report.type).toString()),
        excel.TextCellValue(DateFormat('dd/MM/yyyy HH:mm').format(report.createdAt).toString()),
        excel.TextCellValue(_getStatusLabel(report.status).toString()),
        excel.TextCellValue(user.toString()),
        excel.TextCellValue(fungsi.toString()),
        excel.TextCellValue(detail.toString()),
        excel.TextCellValue((report.data['approved_by_name'] ?? report.data['processed_by'] ?? '-').toString()),
        excel.TextCellValue((report.data['catatan_tambahan'] ?? '-').toString()),
